# ── MongoDB ───────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/ems
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/ems
MONGODB_URI=mongodb://localhost:27017/ems

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=8h

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Admin setup ──────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@company.com
SUPER_ADMIN_PASSWORD=Admin@1234
SUPER_ADMIN_NAME=System Admin

# ── Email (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── Attendance ───────────────────────────────────────────────
OFFICE_START_HOUR=9
OFFICE_START_MINUTE=0
GRACE_PERIOD_MINUTES=15
AUTO_LOGOUT_HOURS=10
